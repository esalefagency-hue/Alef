<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AURA — Community Management Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0A0A0A;
    --gold: #C9A84C;
    --gold-light: #F0D080;
    --cream: #F5F2EC;
    --gray: #555555;
    --bg: #F5F2EC;
    --surface: #FFFFFF;
    --border: rgba(10,10,10,0.10);
    --font-display: 'Playfair Display', serif;
    --font-body: 'DM Sans', sans-serif;
    --radius: 14px;
    --radius-sm: 8px;
    --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
  }

  body {
    background: var(--bg);
    color: var(--black);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: 260px;
    min-height: 100vh;
    background: var(--black);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
  }

  .sidebar-logo {
    padding: 32px 28px 24px;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }

  .logo-mark {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--gold);
    letter-spacing: 4px;
    font-weight: 700;
  }

  .logo-sub {
    font-size: 10px;
    letter-spacing: 3px;
    color: rgba(245,242,236,0.35);
    text-transform: uppercase;
    margin-top: 2px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(245,242,236,0.25);
    padding: 16px 12px 6px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    color: rgba(245,242,236,0.55);
    cursor: pointer;
    transition: var(--transition);
    font-size: 14px;
    font-weight: 400;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .nav-item:hover {
    background: rgba(201,168,76,0.08);
    color: var(--gold-light);
  }

  .nav-item.active {
    background: rgba(201,168,76,0.14);
    color: var(--gold);
    font-weight: 500;
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nav-icon svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sidebar-footer {
    padding: 20px 16px;
    border-top: 1px solid rgba(201,168,76,0.12);
  }

  .user-pill {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition);
  }

  .user-pill:hover { background: rgba(255,255,255,0.05); }

  .user-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 600; color: var(--black);
    flex-shrink: 0;
  }

  .user-name { font-size: 13px; color: rgba(245,242,236,0.7); font-weight: 400; }
  .user-role { font-size: 11px; color: rgba(245,242,236,0.3); }

  /* ─── MAIN ─── */
  .main {
    margin-left: 260px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .topbar {
    position: sticky;
    top: 0;
    background: rgba(245,242,236,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 50;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    color: var(--black);
  }

  .topbar-actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    border: 1px solid transparent;
    letter-spacing: 0.2px;
  }

  .btn-primary {
    background: var(--black);
    color: var(--gold);
    border-color: var(--black);
  }

  .btn-primary:hover {
    background: #1a1a1a;
    box-shadow: 0 4px 16px rgba(10,10,10,0.18);
  }

  .btn-ghost {
    background: transparent;
    color: var(--gray);
    border-color: var(--border);
  }

  .btn-ghost:hover {
    background: rgba(10,10,10,0.05);
    color: var(--black);
  }

  .btn svg {
    width: 15px; height: 15px;
    stroke: currentColor; fill: none;
    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
  }

  /* ─── CONTENT ─── */
  .content {
    padding: 40px;
    flex: 1;
  }

  /* ─── VIEWS ─── */
  .view { display: none; }
  .view.active { display: block; }

  /* ─── DASHBOARD ─── */
  .section-header {
    margin-bottom: 28px;
  }

  .section-headline {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    color: var(--black);
    line-height: 1.2;
  }

  .section-headline em {
    font-style: italic;
    color: var(--gold);
  }

  .section-sub {
    font-size: 14px;
    color: var(--gray);
    margin-top: 6px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 36px;
  }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px 24px;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
    cursor: default;
  }

  .metric-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    opacity: 0;
    transition: var(--transition);
  }

  .metric-card:hover { box-shadow: 0 6px 24px rgba(10,10,10,0.07); }
  .metric-card:hover::before { opacity: 1; }

  .metric-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 400;
    margin-bottom: 10px;
  }

  .metric-value {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    color: var(--black);
    line-height: 1;
  }

  .metric-change {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 8px;
    font-size: 12px;
    color: #2d7a4f;
    font-weight: 500;
  }

  .metric-change.down { color: #a0352e; }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 26px 28px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 400;
    color: var(--black);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-title-badge {
    font-family: var(--font-body);
    font-size: 11px;
    background: rgba(201,168,76,0.12);
    color: var(--gold);
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  /* Upcoming posts */
  .post-list { display: flex; flex-direction: column; gap: 10px; }

  .post-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: var(--transition);
    cursor: pointer;
  }

  .post-item:hover { background: rgba(201,168,76,0.04); border-color: rgba(201,168,76,0.3); }

  .post-platform {
    width: 34px; height: 34px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .post-platform.ig { background: #F3E8FF; color: #7C3AED; }
  .post-platform.tw { background: #E0F2FE; color: #0369A1; }
  .post-platform.li { background: #DBEAFE; color: #1D4ED8; }
  .post-platform.fb { background: #EEF2FF; color: #4338CA; }

  .post-info { flex: 1; min-width: 0; }
  .post-text { font-size: 13px; font-weight: 400; color: var(--black); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .post-meta { font-size: 11px; color: var(--gray); margin-top: 2px; }

  .post-status {
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 20px;
    font-weight: 500;
    flex-shrink: 0;
  }

  .status-scheduled { background: rgba(201,168,76,0.1); color: #9a7a2a; }
  .status-draft { background: rgba(85,85,85,0.1); color: var(--gray); }
  .status-published { background: rgba(45,122,79,0.1); color: #2d7a4f; }

  /* Chart bar */
  .mini-bars {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 100px;
    margin-top: 8px;
  }

  .bar-group { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; }

  .bar {
    width: 100%;
    border-radius: 3px 3px 0 0;
    background: var(--gold-light);
    transition: height 0.6s cubic-bezier(0.4,0,0.2,1);
    position: relative;
  }

  .bar.gold { background: var(--gold); }
  .bar-label { font-size: 10px; color: var(--gray); }

  /* ─── PLANNER / CALENDAR ─── */
  .calendar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .cal-month {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
  }

  .cal-nav { display: flex; gap: 6px; }

  .cal-btn {
    width: 34px; height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
    color: var(--gray);
  }

  .cal-btn:hover { background: var(--black); color: var(--gold); border-color: var(--black); }
  .cal-btn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .cal-day-header {
    background: var(--black);
    color: rgba(245,242,236,0.5);
    text-align: center;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 10px 0;
    font-weight: 400;
    text-transform: uppercase;
  }

  .cal-day {
    background: var(--surface);
    min-height: 90px;
    padding: 8px;
    cursor: pointer;
    transition: background var(--transition);
    position: relative;
  }

  .cal-day:hover { background: rgba(201,168,76,0.04); }
  .cal-day.other-month { background: #faf9f7; }
  .cal-day.today { background: rgba(201,168,76,0.06); }
  .cal-day.today .day-num { background: var(--gold); color: var(--black); border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-weight: 600; }

  .day-num {
    font-size: 13px;
    color: var(--black);
    font-weight: 400;
    margin-bottom: 6px;
    width: 24px; height: 24px;
    display: flex; align-items: center; justify-content: center;
  }

  .cal-day.other-month .day-num { color: rgba(10,10,10,0.2); }

  .cal-post-dot {
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
    font-weight: 500;
  }

  .dot-ig { background: #F3E8FF; color: #7C3AED; }
  .dot-tw { background: #E0F2FE; color: #0369A1; }
  .dot-li { background: #DBEAFE; color: #1D4ED8; }
  .dot-fb { background: #EEF2FF; color: #4338CA; }
  .dot-gold { background: rgba(201,168,76,0.18); color: #9a7a2a; }

  /* ─── CONTENT CREATOR ─── */
  .creator-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
  }

  .form-group { margin-bottom: 20px; }

  label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 8px;
  }

  input[type="text"], input[type="date"], select, textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--black);
    background: var(--surface);
    transition: var(--transition);
    outline: none;
    resize: vertical;
  }

  input[type="text"]:focus, input[type="date"]:focus, select:focus, textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
  }

  textarea { min-height: 120px; line-height: 1.6; }

  .platform-picker {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .platform-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    font-size: 13px;
    color: var(--gray);
    transition: var(--transition);
    font-family: var(--font-body);
  }

  .platform-chip:hover { border-color: var(--gold); color: var(--black); }
  .platform-chip.selected { background: var(--black); color: var(--gold); border-color: var(--black); }

  .tag-input {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    min-height: 42px;
    cursor: text;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    background: rgba(201,168,76,0.12);
    color: #9a7a2a;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }

  .tag button {
    background: none; border: none; cursor: pointer;
    color: inherit; font-size: 14px; line-height: 1; padding: 0;
  }

  .preview-card {
    background: var(--black);
    border-radius: var(--radius);
    padding: 28px;
    position: sticky;
    top: 80px;
  }

  .preview-title {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(245,242,236,0.3);
    margin-bottom: 20px;
  }

  .preview-phone {
    background: #1a1a1a;
    border-radius: 20px;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .preview-post-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .preview-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
  }

  .preview-username { font-size: 13px; color: rgba(245,242,236,0.85); font-weight: 500; }
  .preview-handle { font-size: 11px; color: rgba(245,242,236,0.35); }

  .preview-body {
    font-size: 13px;
    color: rgba(245,242,236,0.7);
    line-height: 1.6;
    min-height: 60px;
    margin-bottom: 14px;
  }

  .preview-image-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: rgba(255,255,255,0.04);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed rgba(255,255,255,0.1);
    margin-bottom: 14px;
  }

  .preview-image-placeholder svg {
    width: 28px; height: 28px;
    stroke: rgba(255,255,255,0.15);
    fill: none;
    stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
  }

  .preview-hashtags { font-size: 12px; color: rgba(201,168,76,0.7); line-height: 1.6; }

  /* ─── CAMPAIGNS ─── */
  .campaign-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .campaign-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
    cursor: pointer;
  }

  .campaign-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(10,10,10,0.09);
  }

  .campaign-header {
    height: 6px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
  }

  .campaign-header.blue { background: linear-gradient(90deg, #3B82F6, #93C5FD); }
  .campaign-header.emerald { background: linear-gradient(90deg, #10B981, #6EE7B7); }
  .campaign-header.rose { background: linear-gradient(90deg, #F43F5E, #FDA4AF); }
  .campaign-header.violet { background: linear-gradient(90deg, #8B5CF6, #C4B5FD); }
  .campaign-header.amber { background: linear-gradient(90deg, var(--gold), var(--gold-light)); }

  .campaign-body { padding: 22px 24px; }

  .campaign-name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .campaign-desc {
    font-size: 13px;
    color: var(--gray);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .campaign-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 14px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta-label {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray);
  }

  .meta-value {
    font-size: 14px;
    font-weight: 500;
    color: var(--black);
  }

  .progress-bar {
    height: 4px;
    background: rgba(10,10,10,0.08);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 2px;
    transition: width 0.8s ease;
  }

  .progress-label {
    font-size: 11px;
    color: var(--gray);
    display: flex;
    justify-content: space-between;
  }

  /* ─── CREATIVITY ─── */
  .ideas-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .idea-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px 24px;
    transition: var(--transition);
    cursor: pointer;
  }

  .idea-card:hover { border-color: rgba(201,168,76,0.4); box-shadow: 0 4px 20px rgba(201,168,76,0.08); }

  .idea-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    background: rgba(201,168,76,0.1);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
  }

  .idea-icon svg {
    width: 20px; height: 20px;
    stroke: var(--gold); fill: none;
    stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
  }

  .idea-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 400;
    margin-bottom: 6px;
  }

  .idea-desc { font-size: 13px; color: var(--gray); line-height: 1.55; }

  .moodboard {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 8px;
  }

  .mood-tile {
    aspect-ratio: 1;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 13px;
    font-style: italic;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 400;
  }

  .mood-tile:hover { transform: scale(1.04); }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,10,10,0.55);
    z-index: 200;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 36px;
    width: 520px;
    max-width: 90vw;
    position: relative;
    animation: modal-in 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-close {
    position: absolute;
    top: 16px; right: 16px;
    width: 30px; height: 30px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--gray);
    font-size: 18px;
    transition: var(--transition);
  }

  .modal-close:hover { background: var(--black); color: var(--gold); }

  .modal-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 6px;
  }

  .modal-subtitle { font-size: 13px; color: var(--gray); margin-bottom: 24px; }

  /* ─── TOAST ─── */
  .toast-container {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 500;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .toast {
    background: var(--black);
    color: var(--cream);
    padding: 12px 18px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 400;
    border-left: 3px solid var(--gold);
    animation: toast-in 0.3s ease;
    pointer-events: all;
    max-width: 300px;
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ─── MISC ─── */
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 24px 0;
  }

  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--gray);
  }

  .empty-state svg {
    width: 40px; height: 40px;
    stroke: rgba(85,85,85,0.4); fill: none;
    stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round;
    margin: 0 auto 14px;
    display: block;
  }

  .range-slider {
    width: 100%;
    accent-color: var(--gold);
  }

  .tone-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .tone-chip {
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    font-size: 12px;
    color: var(--gray);
    cursor: pointer;
    text-align: center;
    transition: var(--transition);
    font-family: var(--font-body);
  }

  .tone-chip:hover { border-color: var(--gold); color: var(--black); }
  .tone-chip.selected { background: var(--gold); color: var(--black); border-color: var(--gold); font-weight: 600; }

  /* ─── ANALYTICS ─── */
  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .perf-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .perf-row:last-child { border-bottom: none; }

  .perf-platform { font-size: 13px; font-weight: 500; flex: 1; }
  .perf-bar-wrap { flex: 2; }
  .perf-value { font-size: 13px; font-weight: 500; color: var(--gold); text-align: right; min-width: 48px; }

  .perf-mini {
    height: 6px;
    background: rgba(10,10,10,0.07);
    border-radius: 3px;
    overflow: hidden;
  }

  .perf-mini-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 3px;
  }

  .chart-week {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 120px;
    padding-top: 10px;
  }

  .week-bar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
  }

  .week-bar {
    width: 100%;
    border-radius: 4px 4px 0 0;
    min-height: 4px;
    transition: height 0.7s ease;
    position: relative;
  }

  .week-bar.primary { background: var(--gold); }
  .week-bar.secondary { background: rgba(201,168,76,0.25); }
  .week-label { font-size: 10px; color: var(--gray); }

  /* ─── RESPONSIVE ADJUSTMENTS ─── */
  @media (max-width: 1100px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .creator-layout { grid-template-columns: 1fr; }
    .campaign-grid { grid-template-columns: repeat(2, 1fr); }
    .preview-card { position: static; }
  }
</style>
