<!-- TOAST CONTAINER -->
<div class="toast-container" id="toast-container"></div>

<script>
// ── NAVIGATION ──
const pageTitles = {
  dashboard: 'Dashboard',
  planner: 'Planificador editorial',
  creator: 'Crear contenido',
  campaigns: 'Campañas',
  creativity: 'Ideas & Creatividad',
  analytics: 'Analíticas'
};

function navigate(view, btn) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  btn.classList.add('active');
  document.getElementById('page-title').textContent = pageTitles[view];
  if (view === 'planner') renderCalendar();
}

// ── TOAST ──
function showToast(msg) {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(() => t.remove(), 300); }, 2800);
}

// ── MODALS ──
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function openNewPost() { openModal('modal-new-post'); }
function openBriefModal() { openModal('modal-brief'); }

document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

function goToCreator() {
  closeModal('modal-new-post');
  document.querySelectorAll('.nav-item')[2].click();
}

// ── CREATOR ──
function updatePreview() {
  const t = document.getElementById('post-text').value;
  document.getElementById('preview-body').textContent = t || 'El texto de tu publicación aparecerá aquí...';
}

function toggleChip(el) { el.classList.toggle('selected'); }
function selectTone(el) {
  el.closest('.tone-grid').querySelectorAll('.tone-chip').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}

function addHashtag(e, input) {
  if (e.key === 'Enter' || e.key === ' ') {
    e.preventDefault();
    const val = input.value.trim().replace(/^#/, '');
    if (!val) return;
    const container = document.getElementById('hashtag-input');
    const tag = document.createElement('span');
    tag.className = 'tag';
    tag.innerHTML = `#${val} <button onclick="removeTag(this.parentElement)">×</button>`;
    container.insertBefore(tag, input);
    input.value = '';
    updateHashtagPreview();
  }
}

function removeTag(tag) {
  tag.remove();
  updateHashtagPreview();
}

function updateHashtagPreview() {
  const tags = [...document.querySelectorAll('#hashtag-input .tag')].map(t => t.textContent.replace('×','').trim());
  document.getElementById('preview-hashtags').textContent = tags.join(' ');
}

// ── CALENDAR ──
let calYear = 2025, calMonth = 4; // May 2025

const MONTHS_ES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DAYS_ES = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];

const samplePosts = {
  '2025-5-2': [{text:'Carrusel primavera', cl:'dot-ig'}],
  '2025-5-5': [{text:'Thread sostenibilidad', cl:'dot-tw'}, {text:'Newsletter', cl:'dot-li'}],
  '2025-5-8': [{text:'Reel producto', cl:'dot-ig'}],
  '2025-5-12': [{text:'Caso de éxito', cl:'dot-li'}],
  '2025-5-14': [{text:'Story promoción', cl:'dot-ig'}, {text:'Post FB', cl:'dot-fb'}],
  '2025-5-19': [{text:'Lanzamiento collab', cl:'dot-gold'}],
  '2025-5-22': [{text:'Encuesta', cl:'dot-fb'}],
  '2025-5-26': [{text:'Contenido educativo', cl:'dot-li'}],
  '2025-5-29': [{text:'Reels viral', cl:'dot-ig'}, {text:'Twitter Q&A', cl:'dot-tw'}],
};

function changeMonth(dir) {
  calMonth += dir;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
}

function renderCalendar() {
  document.getElementById('cal-month-label').textContent = `${MONTHS_ES[calMonth]} ${calYear}`;
  const grid = document.getElementById('calendar-grid');
  grid.innerHTML = '';

  DAYS_ES.forEach(d => {
    const h = document.createElement('div');
    h.className = 'cal-day-header';
    h.textContent = d;
    grid.appendChild(h);
  });

  const first = new Date(calYear, calMonth, 1);
  let startDow = first.getDay(); // 0=Sun
  startDow = (startDow + 6) % 7; // Mon-based

  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  const daysInPrev = new Date(calYear, calMonth, 0).getDate();
  const today = new Date();

  let cells = [];
  for (let i = startDow - 1; i >= 0; i--) cells.push({ d: daysInPrev - i, other: true });
  for (let i = 1; i <= daysInMonth; i++) cells.push({ d: i, other: false });
  while (cells.length % 7 !== 0) cells.push({ d: cells.length - daysInMonth - startDow + 1, other: true });

  cells.forEach(({ d, other }) => {
    const el = document.createElement('div');
    el.className = 'cal-day' + (other ? ' other-month' : '');
    const isToday = !other && d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear();
    if (isToday) el.classList.add('today');

    const num = document.createElement('div');
    num.className = 'day-num';
    num.textContent = d;
    el.appendChild(num);

    if (!other) {
      const key = `${calYear}-${calMonth + 1}-${d}`;
      (samplePosts[key] || []).forEach(p => {
        const dot = document.createElement('div');
        dot.className = `cal-post-dot ${p.cl}`;
        dot.textContent = p.text;
        dot.onclick = () => showToast(`Post: ${p.text}`);
        el.appendChild(dot);
      });
    }

    el.onclick = e => {
      if (e.target.classList.contains('cal-post-dot')) return;
      if (!other) showToast(`Día ${d} de ${MONTHS_ES[calMonth]} seleccionado`);
    };
    grid.appendChild(el);
  });
}

